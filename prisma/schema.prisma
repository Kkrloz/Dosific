generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id             String         @id @default(cuid())
  name           String
  categoryId     String
  category       Category       @relation(fields: [categoryId], references: [id])
  url            String?
  packageWeight  Float
  unit           String
  doseSize       Float
  doseUnit       String
  bonus          Float?
  lastPrice      Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  prices         PriceHistory[]
}

model PriceHistory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  price     Float
  createdAt DateTime @default(now())
}
